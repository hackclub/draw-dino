HACKCLUB_CLIENT_ID=your_hackclub_client_id_dev
HACKCLUB_CLIENT_SECRET=your_hackclub_client_secret_dev
HACKCLUB_REDIRECT_URI=http://localhost:3000/api/hca/callback
PASSPORT_SESSION_SECRET=replace_with_a_long_random_secret

# Optional override for cookie signing state. Falls back to PASSPORT_SESSION_SECRET.
HCA_STATE_SECRET=replace_with_a_long_random_secret

NEXT_PUBLIC_HACKCLUB_AUTH_URL=http://localhost:3000/api/hca/start

# Required by pages/api/github/exchange.js
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_oauth_app_client_id_dev
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret_dev
